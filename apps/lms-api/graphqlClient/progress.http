### Create Unit Progress

GRAPHQL {{base}} HTTP/1.1
Accept: application/json

mutation CreateUnitProgress($input: CreateUnitProgressInput!) {
  createUnitProgress(createUnitProgressInput: $input) {
    userId
    id
    unitId
    isCompleted
    createdAt
  }
}

{
  "input": {
    "isCompleted": true,
    "unitId": "89a457df-238b-4603-b6be-9df386a566b7",
    "userId": "c3b67ca3-44a1-4f05-a511-980758b24176"
  }
}


### Create Tutorial Progress

GRAPHQL {{base}} HTTP/1.1
Accept: application/json

mutation CreateTutorialProgress($input: CreateTutorialProgressInput!) {
  createTutorialProgress(createTutorialProgressInput: $input) {
    id
    userId
    tutorialId
    percentage
    currentUnitId
    isCompleted
    createdAt
  }
}

{
  "input": {
    "isCompleted": false,
    "percentage": 0,
    "tutorialId": "uuid-here",
    "userId": "uuid-here"
  }
}


### Get All Tutorial Progress

GRAPHQL {{base}} HTTP/1.1
Accept: application/json

query {
  tutorialProgress {
    id
    userId
    tutorialId
    percentage
    currentUnitId
    isCompleted
    createdAt
    user {
      id
      username
      email
    }
  }
}


### Get All Unit Progress

GRAPHQL {{base}} HTTP/1.1
Accept: application/json

query {
  unitProgress {
    id
    userId
    unitId
    isCompleted
    createdAt
    user {
      id
      username
      email
    }
  }
}


### Get Tutorial Progress By ID

GRAPHQL {{base}} HTTP/1.1
Accept: application/json

query GetTutorialProgressById($id: ID!) {
  tutorialProgress(id: $id) {
    id
    userId
    tutorialId
    percentage
    currentUnitId
    isCompleted
    createdAt
    user {
      id
      username
      email
    }
  }
}

{
  "id": "uuid-here"
}


