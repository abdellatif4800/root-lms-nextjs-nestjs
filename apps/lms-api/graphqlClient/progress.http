### Update Unit Progress

GRAPHQL {{base}} HTTP/1.1
Accept: application/json

mutation UpdateUnitProgress($input: UpdateUnitProgressInput!) {
  updateUnitProgress(updateUnitProgressInput: $input) {
    id
    isCompleted
  }
}

{
  "input": {
    "id": "uuid-here",
    "isCompleted": true
  }
}


### Update Tutorial Progress

GRAPHQL {{base}} HTTP/1.1
Accept: application/json

mutation UpdateTutorialProgress($input: UpdateTutorialProgressInput!) {
  updateTutorialProgress(updateTutorialProgressInput: $input) {
    id
    percentage
    currentUnitId
    isCompleted
  }
}

{
  "input": {
    "currentUnitId": "uuid-here",
    "id": "uuid-here",
    "isCompleted": false,
    "percentage": 50
  }
}


