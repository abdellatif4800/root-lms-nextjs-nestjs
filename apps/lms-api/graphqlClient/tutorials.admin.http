### update tutorila

GRAPHQL {{adminBase}} HTTP/1.1
Accept: application/json

mutation UpdateTutorial($input: UpdateTutorialInput!) {
  updateTutorial(updateTutorialInput: $input) {
    id
    tutorialName
    description
    level
    thumbnail
    publish
    authorId
    units {
      content
      id
      tutorialId
      order
      publish
      unitTitle
    }
  }
}

