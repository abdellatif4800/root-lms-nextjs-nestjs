### create tutorila

GRAPHQL https://vercel-nest-gql-lms.vercel.app/graphql HTTP/1.1
Accept: application/json

mutation CreateTutorial($input: CreateTutorialInput!) {
  createTutorial(input: $input) {
    id
    tutorialName
    description
    level
    thumbnail
    publish
    units {
      content
      id
      tutorialId
      order
      unitTitle
    }
  }
}

