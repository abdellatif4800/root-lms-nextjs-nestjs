### update whole roadmap

GRAPHQL https://vercel-nest-gql-lms.vercel.app/graphql HTTP/1.1
Accept: application/json

mutation UpdateRoadmap($input: UpdateRoadmapInput!) {
  updateRoadmap(input: $input) {
    id
    title
    nodes {
      id
      clientId
      positionY
      positionX
      tutorial {
        id
        tutorialName
      }
    }
    edges {
      id
      sourceNodeId
      targetNodeId
      sourceClientId
      targetClientId
    }
    author {
      id
    }
    description
    createdAt
    updatedAt
  }
}

