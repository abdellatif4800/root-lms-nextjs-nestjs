### create whole roadmap

GRAPHQL {{base}} HTTP/1.1
Accept: application/json

mutation CreateRoadmap($input: CreateRoadmapInput!) {
  createRoadmap(input: $input) {
    id
    title
    description
    authorId
    nodes {
      id
      clientId
      tutorial {
        id
        tutorialName
      }
      positionX
      positionY
    }
    edges {
      id
      sourceNodeId
      targetNodeId
    }
  }
}

{
  "input": {
    "authorId": "c3b67ca3-44a1-4f05-a511-980758b24176",
    "description": "A roadmap for learning web development",
    "edges": [
      {
        "sourceNodeId": "node-1",
        "targetNodeId": "node-2"
      }
    ],
    "nodes": [
      {
        "clientId": "node-1",
        "positionX": 100,
        "positionY": 200,
        "tutorialId": "56d8577f-d102-4fac-812a-1b97d71ddf9c"
      },
      {
        "clientId": "node-2",
        "positionX": 300,
        "positionY": 200,
        "tutorialId": "4156777c-af75-47ee-abe6-880ab94b855c"
      }
    ],
    "title": "My Learning Roadmap"
  }
}


