{
  "name": "@repo/ui",
  "version": "0.0.0",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./styles.css": "./dist/index.css"
  },
  "license": "MIT",
  "scripts": {
    "build:styles": "tailwindcss -i ./src/styles.css -o ./dist/index.css",
    "build:components": "tsc",
    "check-types": "tsc --noEmit",
    "dev:styles": "tailwindcss -i ./src/styles.css -o ./dist/index.css --watch",
    "dev:components": "tsc --watch",
    "lint": "eslint src --max-warnings 0"
  },
  "peerDependencies": {
    "flowbite": "^4.0.1",
    "flowbite-react": "^0.12.16",
    "@repo/gql": "workspace:*",
    "@repo/reduxSetup": "workspace:*",
    "@repo/mdxSetup": "workspace:*",
    "@repo/reactFlowSetup": "workspace:*",
    "@tiptap/extension-bold": "^3.16.0",
    "@tiptap/extension-code-block": "^3.16.0",
    "@tiptap/extension-code-block-lowlight": "^3.17.1",
    "@tiptap/extension-details": "^3.17.1",
    "@tiptap/extension-emoji": "^3.17.1",
    "@tiptap/extension-hard-break": "^3.17.1",
    "@tiptap/extension-heading": "^3.17.1",
    "@tiptap/extension-horizontal-rule": "^3.17.1",
    "@tiptap/extension-image": "^3.17.1",
    "@tiptap/extension-link": "^3.17.1",
    "@tiptap/extension-list": "^3.17.1",
    "@tiptap/extension-mathematics": "^3.17.1",
    "@tiptap/extension-mention": "^3.17.1",
    "@tiptap/extension-placeholder": "^3.17.1",
    "@tiptap/extension-table": "^3.17.1",
    "@tiptap/extension-text": "^3.17.1",
    "@tiptap/extension-text-style": "^3.17.1",
    "@tiptap/extension-underline": "^3.16.0",
    "@tiptap/extension-youtube": "^3.17.1",
    "@tiptap/extensions": "^3.17.1",
    "@tiptap/pm": "^3.16.0",
    "@tiptap/react": "^3.16.0",
    "@tiptap/starter-kit": "^3.16.0",
    "katex": "^0.16.28",
    "next-themes": "*",
    "next": "*",
    "react": "*"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/tailwind-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/cli": "^4.1.5",
    "@types/node": "*",
    "@types/react": "*",
    "eslint": "^9.39.1",
    "tailwindcss": "*",
    "typescript": "*"
  }
}
